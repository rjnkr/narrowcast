.env
section1-slides.json
section2-slides.json
applications.json
notes.json

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── OS / IDE ──────────────────────────────────────────────────────────────────
.DS_Store
/.idea/
.vscode/
/pipdrive.json
