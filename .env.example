
# ── Docker Hub ────────────────────────────────────────────────────────────────
DOCKERHUB_USERNAME=

# ── Configurable slide sections ───────────────────────────────────────────────
# Each section is a path to a JSON file with an array of iframe slide entries.
# Entry fields: url (required), label (required), duration (ms, optional),
#               from (HH:MM, optional — only show from this time)
# If the path is not set the section is silently omitted.
# See section-slides.example.json for the format.
#
# Section 1 appears at the start of the rotation (e.g. Traffic Viewer, Status)
SLIDES_SECTION1_CONFIG=./applications.json
#
# Section 2 appears after NOS news (e.g. Pipedrive, internal dashboards)
SLIDES_SECTION2_CONFIG=./notes.json

# ── MSG slide — Puppeteer screenshot of authenticated tracker page ─────────────
# Leave MSG_URL empty to disable the slide entirely.
MSG_URL=https://tracker.madesmart.nl
MSG_USERNAME=
MSG_PASSWORD=

# ── Server ────────────────────────────────────────────────────────────────────
# Time from which the traffic slide is shown (24h HH:MM)
TRAFFIC_FROM=
PORT=3001
CACHE_DIR=/app/cache
FRONTEND_DIR=/app/public